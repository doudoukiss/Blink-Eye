{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Blink Browser Run Session Trace",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "events"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "performance_event.schema.json"
      }
    },
    "state_snapshots": {
      "type": "array",
      "items": {
        "$ref": "browser_interaction_state.schema.json"
      }
    }
  },
  "additionalProperties": true
}
