{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Blink Browser Perf Bench Result",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "primary_path",
    "metrics",
    "ratings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "primary_path": {
      "type": "string",
      "const": "./scripts/run-local-browser-melo.sh"
    },
    "flags": {
      "type": "object",
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "integer",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "ratings": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "integer",
          "number",
          "null"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
