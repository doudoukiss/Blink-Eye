{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Browser Camera State",
  "type": "object",
  "required": [
    "schema_version",
    "available",
    "state"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "available": {
      "type": "boolean"
    },
    "state": {
      "type": "string",
      "enum": [
        "unreported",
        "ready",
        "audio_only",
        "unavailable",
        "stale",
        "looking",
        "error"
      ]
    },
    "latest_frame_seq": {
      "type": [
        "integer",
        "null"
      ]
    },
    "latest_frame_age_ms": {
      "type": [
        "number",
        "null"
      ]
    },
    "last_vision_turn_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_vision_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
