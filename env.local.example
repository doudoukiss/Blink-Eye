# Local-first Blink development on macOS
# Canonical local env names now use the BLINK_* prefix.

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3.5:4b
# Optional shared prompt override. If you set this, it overrides both the
# default text-chat prompt and lower-level default speech prompt. The English
# native wrappers intentionally ignore inherited prompt overrides unless you
# pass --system-prompt explicitly.
# OLLAMA_SYSTEM_PROMPT=你正在帮助开发者在本地探索 Blink。请始终使用简体中文回答。

# Optional hybrid demo LLM routing. The default remains Ollama.
# BLINK_LOCAL_LLM_PROVIDER=openai-responses
# BLINK_LOCAL_DEMO_MODE=1
# BLINK_LOCAL_LLM_MAX_OUTPUT_TOKENS=120
# BLINK_LOCAL_OPENAI_RESPONSES_MODEL=gpt-5.4-mini
# For hero-flow quality checks, override the wrapper default with:
# BLINK_LOCAL_OPENAI_RESPONSES_MODEL=gpt-5.4
# BLINK_LOCAL_OPENAI_RESPONSES_BASE_URL=
# BLINK_LOCAL_OPENAI_RESPONSES_SERVICE_TIER=
# OPENAI_API_KEY=
# BLINK_LOCAL_LLM_SYSTEM_PROMPT=你正在帮助开发者在本地探索 Blink。请始终使用简体中文回答。
# Optional browser model-selector extension. The file should contain
# {"profiles": [{ "id": "...", "label": "...", "provider": "ollama", "model": "..." }]}.
# BLINK_LOCAL_LLM_MODEL_PROFILES_PATH=
# Remote/OpenAI profiles are locked in the browser selector unless you
# deliberately unlock them for a demo or development run.
# BLINK_LOCAL_ENABLE_REMOTE_MODEL_SELECTION=0

# Optional typed runtime profile. Product wrappers set this themselves; keep
# `.env` for local overrides, paths, ports, and secrets rather than personality
# or media-policy defaults.
# Built-ins live in config/local_runtime_profiles.json.
# BLINK_LOCAL_CONFIG_PROFILE=browser-en-kokoro
# Optional gitignored profile override file. Defaults to .blink-local-profiles.json
# when that file exists.
# BLINK_LOCAL_CONFIG_PROFILES_PATH=

BLINK_LOCAL_LANGUAGE=zh
BLINK_LOCAL_STT_BACKEND=mlx-whisper
# Optional stable local brain user id. Leave unset to use `local_primary`.
# BLINK_LOCAL_BRAIN_USER_ID=local_primary
# Leave this unset for the browser product runtime policy:
# Chinese browser sessions prefer `local-http-wav` when a healthy sidecar is
# available, and otherwise fall back to Kokoro. Native voice is English-only
# Kokoro and does not auto-switch to MeloTTS/local-http-wav.
# Set `BLINK_LOCAL_TTS_BACKEND=kokoro` only if you want to pin the bootstrap
# fallback path explicitly.
# BLINK_LOCAL_TTS_BACKEND=kokoro
BLINK_LOCAL_STT_MODEL=mlx-community/whisper-medium-mlx
BLINK_LOCAL_TTS_VOICE_ZH=zf_xiaobei
BLINK_LOCAL_TTS_VOICE_EN=af_heart
# BLINK_LOCAL_TTS_VOICE=
# These voice env vars are for Kokoro/Piper. The `local-http-wav` path uses the
# sidecar's own speaker catalog instead and falls back to the sidecar default
# when `/voices` says a configured speaker is stale.
BLINK_LOCAL_XTTS_BASE_URL=http://127.0.0.1:8000
BLINK_LOCAL_HTTP_WAV_TTS_BASE_URL=http://127.0.0.1:8001

# Optional audio device overrides for native mic/speaker mode.
BLINK_LOCAL_AUDIO_INPUT_DEVICE=
BLINK_LOCAL_AUDIO_OUTPUT_DEVICE=
# Deprecated no-op for native voice. Use BLINK_LOCAL_CAMERA_SOURCE=macos-helper
# only for the English Kokoro helper path below.
BLINK_LOCAL_VOICE_VISION=0
# Optional macOS-only English Kokoro camera helper path. Build the helper with
# ./scripts/build-macos-camera-helper.sh and run it through
# ./scripts/run-local-voice-macos-camera-en.sh.
BLINK_LOCAL_CAMERA_SOURCE=none
# BLINK_LOCAL_CAMERA_HELPER_APP=native/macos/BlinkCameraHelper/build/BlinkCameraHelper.app
# BLINK_LOCAL_CAMERA_HELPER_STATE_DIR=
# BLINK_LOCAL_IGNORE_ENV_SYSTEM_PROMPT=1
# Keep this empty for lower-level protected playback. The English native wrapper
# scripts force this to 0 for open-speaker stability; pass --allow-barge-in to
# those wrappers only with headphones or another echo-safe setup.
BLINK_LOCAL_ALLOW_BARGE_IN=

# Optional browser/WebRTC host and port overrides.
BLINK_LOCAL_HOST=127.0.0.1
BLINK_LOCAL_PORT=7860

# Browser camera inspection with the local Moondream vision stack. Both the
# canonical browser launchers default to this mode: browser-zh-melo and
# browser-en-kokoro both keep Moondream available unless explicitly disabled.
# Set this to 0 only if you intentionally want audio-only browser mode.
BLINK_LOCAL_BROWSER_VISION=1
BLINK_LOCAL_VISION_MODEL=vikhyatk/moondream2
# Continuous perception remains off by default for both primary browser paths.
# Explicit camera questions still use the on-demand fetch_user_image path.
# BLINK_LOCAL_CONTINUOUS_PERCEPTION=0
# BLINK_LOCAL_CONTINUOUS_PERCEPTION_INTERVAL_SECS=5

# Actor Surface v2 is the default browser UI overlay. Disable only for rollback
# or compatibility debugging.
# BLINK_LOCAL_ACTOR_SURFACE_V2=1
# Actor traces are opt-in and sanitized. Default traces must not store raw
# audio, raw images, SDP, ICE, secrets, prompts, full messages, or unbounded
# transcript text.
# BLINK_LOCAL_ACTOR_TRACE=0
# BLINK_LOCAL_ACTOR_TRACE_DIR=artifacts/actor_traces

# English fallback:
# BLINK_LOCAL_LANGUAGE=en
# BLINK_LOCAL_TTS_BACKEND=kokoro
# BLINK_LOCAL_TTS_VOICE_EN=af_heart

# Optional higher-quality Chinese TTS via the recommended MeloTTS sidecar:
# BLINK_LOCAL_TTS_BACKEND=local-http-wav
# BLINK_LOCAL_HTTP_WAV_TTS_BASE_URL=http://127.0.0.1:8001
# BLINK_LOCAL_MELO_HOST=127.0.0.1
# BLINK_LOCAL_MELO_PORT=8001
# BLINK_LOCAL_MELO_DEVICE=cpu
# BLINK_LOCAL_MELO_SPEAKER_ZH=ZH
# BLINK_LOCAL_MELO_SPEAKER_EN=EN-US
# BLINK_LOCAL_MELO_SPEED=1.0

# Optional XTTS-compatible local service:
# BLINK_LOCAL_TTS_BACKEND=xtts
# BLINK_LOCAL_TTS_VOICE_ZH=
# BLINK_LOCAL_XTTS_BASE_URL=http://127.0.0.1:8000

# Optional advanced CosyVoice -> local-http-wav sidecar:
# BLINK_LOCAL_TTS_BACKEND=local-http-wav
# BLINK_LOCAL_HTTP_WAV_TTS_BASE_URL=http://127.0.0.1:8001
# BLINK_LOCAL_COSYVOICE_BACKEND_URL=http://127.0.0.1:50000
# BLINK_LOCAL_COSYVOICE_MODEL_DIR=iic/CosyVoice-300M-SFT
# BLINK_LOCAL_COSYVOICE_SPEAKER_ZH=中文女
# BLINK_LOCAL_COSYVOICE_SPEAKER_EN=
